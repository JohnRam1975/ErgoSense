# ErgoSense API — variáveis de ambiente (desenvolvimento)
# Copie para .env e preencha. Nunca committe o .env real.
#
# Em produção use: infra/.env.production.example + generate-production-env.*
# O boot com NODE_ENV=production rejeita secrets fracos (productionGuard.js).

# --- Banco ---
PGHOST=localhost
PGPORT=5433
PGDATABASE=ergosense
PGUSER=postgres
PGPASSWORD="your_password_here"
PGPOOL_MAX=20
PGPOOL_IDLE_MS=30000

# --- Runtime ---
PORT=3001
NODE_ENV=development
LOG_LEVEL=info
APP_VERSION=1.0.0
APP_PUBLIC_URL=http://localhost:5173
SERVICE_NAME=ergosense-api

# --- Redis / sessão / cache (opcional local; obrigatório em cluster) ---
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379
CACHE_ENABLED=true
CACHE_DEFAULT_TTL_SEC=60
SESSION_REDIS_ENABLED=false
SESSION_TTL_SEC=604800

# --- Fila (opcional) ---
RABBITMQ_ENABLED=false
RABBITMQ_URL=
RABBITMQ_PREFETCH=5

# --- Storage: database | minio | s3 ---
STORAGE_DRIVER=database
STORAGE_BUCKET=ergosense-media
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_PUBLIC_BASE_URL=

# --- Segurança ---
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=604800
# SECRET_KEY: alias operacional (app usa JWT_* / MFA_*); gere valor aleatório em prod
SECRET_KEY=change-me-secret-key-min-32-chars-xxxx
CSRF_ENABLED=true
CSRF_COOKIE_NAME=ergosense_csrf
REFRESH_COOKIE_NAME=ergosense_refresh
TRUST_PROXY=false
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000
LOGIN_RATE_LIMIT_MAX=10
CRITICAL_RATE_LIMIT_MAX=30
RATE_LIMIT_SKIP_DEV=true
TENANT_ENFORCE=true
TENANT_HEADER=x-tenant-id

# --- MFA ---
MFA_ENABLED=true
MFA_ENCRYPTION_KEY=
MFA_PENDING_SECRET=

# --- Observabilidade ---
METRICS_ENABLED=true
METRICS_TOKEN=
TRACING_ENABLED=true
SUPPORT_CONTACT_EMAIL=ergosense.suporte@dejohn.com.br

# --- IA (somente servidor; nunca no frontend) ---
AI_PROVIDER=openai
AI_MODEL=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
