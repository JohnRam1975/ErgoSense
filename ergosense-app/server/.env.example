PGHOST=localhost
PGPORT=5433
PGDATABASE=ergosense
PGUSER=postgres
PGPASSWORD="your_password_here"
PORT=3001
NODE_ENV=development

# Redis (opcional local; obrigatório em cluster multi-réplica)
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379

# Storage: database | minio | s3
STORAGE_DRIVER=database
STORAGE_BUCKET=ergosense-media
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_PUBLIC_BASE_URL=

# Segurança / observabilidade
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=604800
CSRF_ENABLED=true
METRICS_TOKEN=
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000
LOGIN_RATE_LIMIT_MAX=10
TRUST_PROXY=false
METRICS_ENABLED=true
TENANT_ENFORCE=true
LOG_LEVEL=info
APP_VERSION=1.0.0

# Inteligência artificial (chaves centralizadas no servidor — nunca expor ao frontend)
AI_PROVIDER=openai
AI_MODEL=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
APP_PUBLIC_URL=http://localhost:5173
