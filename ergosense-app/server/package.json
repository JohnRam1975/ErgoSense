{
  "name": "ergosense-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "db:up": "docker compose --env-file ../../infra/.env -f ../../infra/docker-compose.yml up -d db",
    "db:down": "docker compose --env-file ../../infra/.env -f ../../infra/docker-compose.yml stop db",
    "health": "node -e \"fetch('http://localhost:'+(process.env.PORT||3001)+'/health').then(r=>r.json()).then(console.log)\"",
    "fix-utf8": "node scripts/fix-utf8-data.js",
    "migrate:load": "node scripts/migrate-load-assessment.js",
    "migrate:effort": "node scripts/migrate-load-effort.js",
    "migrate:security": "node scripts/migrate-security.js",
    "migrate:risk-inventory": "node scripts/migrate-risk-inventory.js",
    "migrate:gro": "node scripts/migrate-gro-cycle.js",
    "migrate:pgr": "node scripts/migrate-pgr.js",
    "migrate:psicossocial": "node scripts/migrate-psicossocial.js",
    "migrate:aet": "node scripts/migrate-aet.js",
    "migrate:sst": "node scripts/migrate-sst.js",
    "migrate:esocial": "node scripts/migrate-esocial.js",
    "migrate:esocial-transmissions": "node scripts/migrate-esocial-transmissions.js",
    "migrate:compliance": "node scripts/migrate-compliance.js",
    "migrate:risk-integration": "node scripts/migrate-risk-integration.js",
    "migrate:org-structure": "node scripts/migrate-org-structure.js",
    "migrate:aet-corporate": "node scripts/migrate-aet-corporate.js",
    "migrate:compliance-intelligence": "node scripts/migrate-compliance-intelligence.js",
    "migrate:inventario-nr01": "node scripts/migrate-inventario-nr01.js",
    "migrate:denuncia": "node scripts/migrate-denuncia.js",
    "migrate:gro-criterios": "node scripts/migrate-gro-criterios.js",
    "migrate:analise-video": "node scripts/migrate-analise-video.js",
    "test:integration": "node --import ./tests/setup/integration-env.js --test --test-concurrency=1 tests/integration/**/*.integration.test.js",
    "test:integration:container": "node --import ./tests/setup/integration-env.js --test --test-concurrency=1 tests/integration/**/*.integration.test.js",
    "test:inventario": "node --test src/__tests__/riskInventory.unit.test.js",
    "test:denuncia": "node --test src/__tests__/denuncia.unit.test.js",
    "test:criteria": "node --test src/__tests__/riskCriteria.unit.test.js",
    "test:esocial": "node --test src/__tests__/esocial.unit.test.js",
    "test:aet": "node --test src/__tests__/aet.unit.test.js",
    "test:compliance": "node --test src/__tests__/compliance.unit.test.js",
    "test:security": "node --test src/__tests__/security.unit.test.js",
    "test:ai": "node --test src/__tests__/aiConfig.unit.test.js",
    "test:ai-expert": "node --test src/__tests__/aiExpert.unit.test.js",
    "test:security:smoke": "node scripts/security-smoke-test.js",
    "test:security:advanced": "node scripts/security-advanced.js",
    "test:onboarding": "node scripts/onboarding-flow-test.js",
    "test:endpoints": "node scripts/endpoint-inventory.js && node scripts/endpoint-smoke.js && node scripts/endpoint-matrix.js",
    "test:matrix": "node scripts/endpoint-matrix-batch.js",
    "test:matrix:batch": "node scripts/endpoint-matrix-batch.js",
    "test:openapi": "node scripts/generate-openapi.js && node scripts/openapi-gap-test.js",
    "test:migrations:ci": "node scripts/migrations-ci-test.js",
    "seed:audit": "node scripts/seed-audit-user.js",
    "test:db": "node scripts/db-integrity-test.js",
    "coverage": "c8 --exclude scripts --exclude tests --reporter=text --reporter=json-summary --reporter=html --reports-dir=coverage node --import ./tests/setup/integration-env.js --test --test-concurrency=1 src/__tests__/**/*.unit.test.js tests/integration/**/*.integration.test.js",
    "coverage:report": "node scripts/coverage-report.js",
    "coverage:baseline": "node scripts/coverage-baseline-check.js",
    "test:field": "node scripts/field-inspection-ergonomista.js",
    "test": "node --test src/__tests__/**/*.unit.test.js",
    "test:operational": "node scripts/operational-audit.js",
    "test:load": "node scripts/load-test.js",
    "test:resilience": "node scripts/resilience-test.js",
    "test:full": "npm test && node scripts/operational-audit.js && node scripts/load-test.js && node scripts/resilience-test.js",
    "migrate:performance-indexes": "node scripts/migrate-performance-indexes.js",
    "migrate:enterprise": "node scripts/migrate-enterprise.js",
    "migrate:tenant-onboarding": "node scripts/migrate-tenant-onboarding.js",
    "openapi:generate": "node scripts/generate-openapi.js",
    "migrate:storage-external": "node scripts/migrate-storage-external.js",
    "migrate:all": "node scripts/migrate-runner.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1067.0",
    "@xmldom/xmldom": "^0.9.8",
    "amqplib": "^2.0.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.3",
    "node-forge": "^1.3.1",
    "otplib": "^13.4.1",
    "pdfkit": "^0.19.1",
    "pg": "^8.13.3",
    "qrcode": "^1.5.4",
    "xml-crypto": "^6.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^12.0.4",
    "c8": "^10.1.3",
    "supertest": "^7.2.2",
    "testcontainers": "^12.0.4"
  }
}
