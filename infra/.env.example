# Copie para .env e preencha. Nunca committe o .env real.
#
#   cp .env.example .env
#   docker compose --env-file .env pull
#   docker compose --env-file .env up -d
#
# Imagens públicas no GHCR (mesmo padrão FinCare — sem Docker Hub pago)

ERGOSENSE_POSTGRES_IMAGE=ghcr.io/johnram1975/ergosense-postgres:latest
ERGOSENSE_API_IMAGE=ghcr.io/johnram1975/ergosense-api:latest
ERGOSENSE_WEB_IMAGE=ghcr.io/johnram1975/ergosense-web:latest

PUBLIC_HTTP_PORT=80

APP_PUBLIC_URL=https://ergosense.dejohn.com.br
CORS_ORIGINS=https://ergosense.dejohn.com.br

POSTGRES_DB=ergosense
POSTGRES_USER=postgres
POSTGRES_PASSWORD=TROCAR_SENHA_FORTE_PG

MINIO_ROOT_USER=ergosense
MINIO_ROOT_PASSWORD=TROCAR_SENHA_FORTE_MINIO
STORAGE_DRIVER=database
STORAGE_BUCKET=ergosense-media

JWT_ACCESS_SECRET=TROCAR_ACCESS_SECRET_MIN_32_CHARS!!
JWT_REFRESH_SECRET=TROCAR_REFRESH_SECRET_MIN_32_CHARS!
MFA_ENABLED=false
CSRF_ENABLED=true
RUN_MIGRATIONS=true
LOG_LEVEL=info

SEED_GLOBAL_ADMIN_EMAIL=ergosense@dejohn.com.br
SEED_GLOBAL_ADMIN_PASSWORD=@Ergo!2026/Adm
SUPPORT_CONTACT_EMAIL=ergosense.suporte@dejohn.com.br
