# Copie para .env e preencha. Nunca committe o .env real.
#
#   cp .env.example .env
#   # ou produção:
#   powershell -File infra/scripts/generate-production-env.ps1
#   copy .env.production .env
#
#   docker compose --env-file .env pull
#   docker compose --env-file .env up -d
#
# Imagens públicas no GHCR. No VPS com FinCare: porta 80 ocupada → PUBLIC_HTTP_PORT=8088

# Pin por tag de release — NÃO use só :latest
ERGOSENSE_POSTGRES_IMAGE=ghcr.io/johnram1975/ergosense-postgres:20260723-forgotfix
ERGOSENSE_API_IMAGE=ghcr.io/johnram1975/ergosense-api:20260723-forgotfix
ERGOSENSE_WEB_IMAGE=ghcr.io/johnram1975/ergosense-web:20260723-forgotfix

PUBLIC_HTTP_PORT=8088

APP_PUBLIC_URL=https://ergosense.dejohn.com.br
CORS_ORIGINS=https://ergosense.dejohn.com.br

POSTGRES_DB=ergosense
POSTGRES_USER=postgres
# Obrigatório em produção (compose exige). Gere com generate-production-env.
POSTGRES_PASSWORD=TROCAR_SENHA_FORTE_PG_MIN_16

MINIO_ROOT_USER=ergosense
MINIO_ROOT_PASSWORD=TROCAR_SENHA_FORTE_MINIO_MIN_16
STORAGE_DRIVER=minio
STORAGE_BUCKET=ergosense-media

# Secrets — mín. 32 chars aleatórios (sem placeholders em produção)
JWT_ACCESS_SECRET=TROCAR_ACCESS_SECRET_MIN_32_CHARS_XX
JWT_REFRESH_SECRET=TROCAR_REFRESH_SECRET_MIN_32_CHARS_X
MFA_ENCRYPTION_KEY=TROCAR_MFA_ENCRYPTION_KEY_MIN_32_XXX
MFA_PENDING_SECRET=TROCAR_MFA_PENDING_SECRET_MIN_32_XXX
SECRET_KEY=TROCAR_SECRET_KEY_MIN_32_CHARS_XXXXXXX
METRICS_TOKEN=TROCAR_METRICS_TOKEN_MIN_24_CHARS_XXX

MFA_ENABLED=true
CSRF_ENABLED=true
RUN_MIGRATIONS=true
LOG_LEVEL=info
RATE_LIMIT_SKIP_DEV=false

SEED_GLOBAL_ADMIN_EMAIL=admin@seu-dominio.exemplo
SEED_GLOBAL_ADMIN_PASSWORD=TROCAR_SENHA_ADMIN_FORTE
PURGE_DEMO_TENANTS=true
SUPPORT_CONTACT_EMAIL=ergosense.suporte@dejohn.com.br

AI_PROVIDER=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
