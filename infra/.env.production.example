# ErgoSense — template PRODUÇÃO (sem segredos reais)
# Copie para .env.production e rode:
#   powershell -File infra/scripts/generate-production-env.ps1
# ou:
#   ./infra/scripts/generate-production-env.sh
#
# NUNCA commite .env.production com secrets.

ERGOSENSE_POSTGRES_IMAGE=ghcr.io/johnram1975/ergosense-postgres:SUBSTITUIR_TAG
ERGOSENSE_API_IMAGE=ghcr.io/johnram1975/ergosense-api:SUBSTITUIR_TAG
ERGOSENSE_WEB_IMAGE=ghcr.io/johnram1975/ergosense-web:SUBSTITUIR_TAG

PUBLIC_HTTP_PORT=8088
APP_PUBLIC_URL=https://seu-dominio.exemplo
CORS_ORIGINS=https://seu-dominio.exemplo

NODE_ENV=production
POSTGRES_DB=ergosense
POSTGRES_USER=postgres
POSTGRES_PASSWORD=GERAR_COM_SCRIPT_MIN_32

MINIO_ROOT_USER=ergosense
MINIO_ROOT_PASSWORD=GERAR_COM_SCRIPT_MIN_32
STORAGE_DRIVER=minio
STORAGE_BUCKET=ergosense-media

# Secrets (mín. 32 chars aleatórios — generate-production-env)
JWT_ACCESS_SECRET=GERAR_COM_SCRIPT
JWT_REFRESH_SECRET=GERAR_COM_SCRIPT
MFA_ENCRYPTION_KEY=GERAR_COM_SCRIPT
MFA_PENDING_SECRET=GERAR_COM_SCRIPT
SECRET_KEY=GERAR_COM_SCRIPT
METRICS_TOKEN=GERAR_COM_SCRIPT

MFA_ENABLED=true
CSRF_ENABLED=true
TRUST_PROXY=true
RATE_LIMIT_SKIP_DEV=false
TENANT_ENFORCE=true
RUN_MIGRATIONS=true
LOG_LEVEL=info

REDIS_ENABLED=true
SESSION_REDIS_ENABLED=true

SEED_GLOBAL_ADMIN_EMAIL=admin@seu-dominio.exemplo
SEED_GLOBAL_ADMIN_PASSWORD=GERAR_COM_SCRIPT
PURGE_DEMO_TENANTS=true
SUPPORT_CONTACT_EMAIL=suporte@seu-dominio.exemplo

AI_PROVIDER=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
