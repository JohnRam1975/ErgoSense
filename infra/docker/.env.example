# Copie para infra/docker/.env antes de: docker compose -f docker-compose.cloud.yml up -d

POSTGRES_DB=ergosense
POSTGRES_USER=postgres
POSTGRES_PASSWORD=altere_sua_senha
POSTGRES_PUBLISH_PORT=5434

MINIO_ROOT_USER=ergosense
MINIO_ROOT_PASSWORD=altere_minio_senha

RABBITMQ_USER=ergosense
RABBITMQ_PASSWORD=altere_rabbit_senha
RABBITMQ_PUBLISH_PORT=5672
RABBITMQ_MGMT_PORT=15672

GATEWAY_PORT=8080
CORS_ORIGINS=http://localhost:8080
APP_PUBLIC_URL=http://localhost:8080

JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-local
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-local

GRAFANA_USER=admin
GRAFANA_PASSWORD=altere_grafana

# Registry (opcional — se usar imagens em vez de build)
# IMAGE_REGISTRY=seuuser
# IMAGE_TAG=1.0.0
