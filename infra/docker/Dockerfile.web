# ErgoSense Web — Vite build + Nginx (SPA + proxy /api)
# context: raiz do repositório
# Hostinger: imagem pronta; sem build no VPS
FROM node:22-alpine AS build
WORKDIR /app
COPY ergosense-app/package.json ergosense-app/package-lock.json* ./
RUN npm ci 2>/dev/null || npm install
COPY ergosense-app/ ./
# Evita tsc -b (erros TS legados) — artefato de produção via Vite
ARG VITE_API_URL=/api
ENV VITE_API_URL=$VITE_API_URL
RUN npx vite build

FROM nginx:1.27-alpine
COPY infra/docker/nginx/hostinger.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
RUN chown -R nginx:nginx /usr/share/nginx/html
EXPOSE 80
HEALTHCHECK --interval=30s --timeout=3s --retries=3 \
  CMD wget -qO- http://127.0.0.1/ || exit 1
