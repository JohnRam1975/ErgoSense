{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "title": "Latência P95 (ms)",
      "type": "graph",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum(rate(ergosense_http_request_duration_ms_bucket[5m])) by (le))",
        "legendFormat": "p95"
      }]
    },
    {
      "title": "Memória RSS",
      "type": "graph",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [{ "expr": "ergosense_process_memory_bytes{type=\"rss\"}", "legendFormat": "rss" }]
    },
    {
      "title": "Filas — publicações",
      "type": "graph",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 8 },
      "targets": [{ "expr": "sum by (queue) (rate(ergosense_queue_publish_total[5m]))", "legendFormat": "{{queue}}" }]
    },
    {
      "title": "Filas — erros",
      "type": "graph",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 8 },
      "targets": [{ "expr": "sum by (queue) (rate(ergosense_queue_errors_total[5m]))", "legendFormat": "{{queue}}" }]
    },
    {
      "title": "Requisições IA",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 14 },
      "targets": [{ "expr": "ergosense_ai_requests_total", "legendFormat": "ai" }]
    }
  ],
  "schemaVersion": 39,
  "tags": ["ergosense", "operacional"],
  "title": "ErgoSense — Operacional",
  "uid": "ergosense-ops",
  "version": 1
}
