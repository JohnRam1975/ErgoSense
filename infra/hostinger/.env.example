# =============================================================================
# ErgoSense — variáveis Hostinger (cole no Docker Manager / environment)
# NÃO commitar valores reais.
# =============================================================================

# Imagens (mesmo registry usado no build-and-push)
IMAGE_REGISTRY=SEU_DOCKERHUB_OU_GHCR/seu-usuario
IMAGE_TAG=1.0.0

# Porta pública do VPS (Hostinger: 80; se usar Cloudflare/SSL na frente, 80 ok)
PUBLIC_HTTP_PORT=80

# Domínio público (HTTPS)
APP_PUBLIC_URL=https://ergosense.dejohn.com.br
CORS_ORIGINS=https://ergosense.dejohn.com.br

# Postgres
POSTGRES_DB=ergosense
POSTGRES_USER=postgres
POSTGRES_PASSWORD=TROCAR_SENHA_FORTE_PG

# JWT / MFA (gere com: openssl rand -hex 32)
JWT_ACCESS_SECRET=TROCAR_ACCESS_SECRET_MIN_32_CHARS
JWT_REFRESH_SECRET=TROCAR_REFRESH_SECRET_MIN_32_CHARS
MFA_ENCRYPTION_KEY=
MFA_PENDING_SECRET=
MFA_ENABLED=true
CSRF_ENABLED=true

# Ops
RUN_MIGRATIONS=true
STORAGE_DRIVER=database
LOG_LEVEL=info
METRICS_TOKEN=

# Admin global opcional (seed no boot — só se o script existir e DB vazio)
SEED_GLOBAL_ADMIN_EMAIL=ergosense@dejohn.com.br
SEED_GLOBAL_ADMIN_PASSWORD=@Ergo!2026/Adm
SEED_GLOBAL_ADMIN_NAME=Administrador Global

# IA (opcional)
AI_PROVIDER=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
